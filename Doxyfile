# Doxygen configuration for the R7FA4M2 Multi-Click Smartwatch example.

PROJECT_NAME           = "R7FA4M2 Multi-Click Smartwatch"
PROJECT_BRIEF          = "Bare-metal multi-screen smartwatch demo for Clicker 4 for R7FA4M2A"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = README.md include src
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO

GENERATE_LATEX         = NO
GENERATE_XML           = NO
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = YES
EXTENSION_MAPPING      = md=markdown
IMAGE_PATH             = .
